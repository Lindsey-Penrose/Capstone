="13" value="70"/><column index="14" value="73"/><column index="15" value="75"/><column index="16" value="75"/><column index="17" value="93"/><column index="18" value="79"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats><column index="10" value=""/></display_formats><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="synthetic_health_claims" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/><column index="2" value="103"/><column index="3" value="69"/><column index="4" value="85"/><column index="5" value="91"/><column index="6" value="147"/><column index="7" value="101"/><column index="8" value="85"/><column index="9" value="104"/><column index="10" value="109"/><column index="11" value="93"/><column index="12" value="84"/><column index="13" value="140"/><column index="14" value="132"/><column index="15" value="109"/><column index="17" value="109"/><column index="18" value="111"/><column index="19" value="151"/><column index="20" value="109"/><column index="21" value="226"/><column index="22" value="139"/><column index="23" value="117"/><column index="24" value="131"/><column index="25" value="105"/><column index="26" value="225"/><column index="27" value="232"/><column index="28" value="201"/><column index="29" value="144"/><column index="30" value="96"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">select Admission_Type, count(is_fraudulent) as ConfirmedFraud
from synthetic_health_claims
where Is_Fraudulent = 'True'
group by Admission_Type
order by confirmedfraud DESC
</sql><sql name="SQL 2">select count(Claim_Date) as ClaimsMadeIn2025
from synthetic_health_claims
where Claim_Date like '2025%'
</sql><sql name="SQL 3">select strftime('%Y', claim_date),count(Claim_Date), Admission_Type
from synthetic_health_claims
group by strftime('%Y', claim_date)
order by strftime('%Y', claim_date) desc</sql><sql name="SQL 4">select count(Claim_Date),strftime('%Y', claim_date)
from synthetic_health_claims
group by strftime('%Y', claim_date)</sql><sql name="SQL 5">select patient_age, count(patient_age)
from synthetic_health_claims
group by Patient_Age
order by Patient_Age 
</sql><sql name="SQL 6*">select ExclType, count(exclType), DEFINITION
from LEIE_Database
left join fraudcodes on LEIE_Database.ExclType = FraudCodes.CODE
where DEFINITION not null
group by ExclType
order by count(exclTYpe) desc</sql><current_tab id="5"/></tab_sql></sqlb_project>
